{
  "name": "polymarket-search",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/search.test.js",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py' -v",
    "eval": "node scripts/eval.mjs",
    "check:index-health": "python3 scripts/check_index_health.py",
    "build": "python3 scripts/build-index.py",
    "build:archived": "python3 scripts/build-index.py --archived",
    "build:kalshi": "python3 scripts/build-kalshi-index.py",
    "build:kalshi:archived": "python3 scripts/build-kalshi-index.py --archived --metadata-cache-only --max-pages 100",
    "build:manifold": "python3 scripts/build-manifold-index.py",
    "build:local": "python3 scripts/build-index.py --local data/events_active.jsonl",
    "serve": "python3 -m http.server -d public 3000"
  }
}
